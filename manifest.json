{
  "manifest_version": 3,
  "name": "LinkedIn AI Profiler",
  "version": "1.0",
  "description": "Analyze LinkedIn profiles and get AI-powered career suggestions.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "improvement.html",
    "default_title": "Configure AI Profiler"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/in/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
